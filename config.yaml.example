database:
  url: "postgres://finagent:secret@localhost:5432/finagent?sslmode=disable"
  max_connections: 10
  auto_migrate: true

llm:
  base_url: "http://localhost:11434/v1"
  api_key: ""  # FINAGENT_LLM__API_KEY
  routing:
    chat_model:      "qwen3:14b"
    analysis_model:  "qwen3:14b"
    tagging_model:   "qwen3:14b"
    embed_model:     "nomic-embed-text"
    summarize_model: "qwen3:14b"

agent:
  max_tool_rounds:  20
  history_messages: 20

channel:
  cli:
    default_user: "alice"

api:
  listen: ":8082"

users:
  - username: "alice"
    name: "Alice"
    email: "alice@example.com"
    timezone: "Asia/Kolkata"

api_keys:
  alice: "changeme"  # FINAGENT_API_KEYS__ALICE