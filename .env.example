# Database
FINAGENT_DATABASE__URL=postgres://user:password@localhost:5432/finagent?sslmode=disable
FINAGENT_DATABASE__MAX_CONNECTIONS=10
FINAGENT_DATABASE__AUTO_MIGRATE=true

# LLM provider (OpenAI-compatible)
FINAGENT_LLM__BASE_URL=http://localhost:11434/v1
FINAGENT_LLM__API_KEY=

# Model routing (leave empty to use config.yaml defaults)
FINAGENT_LLM__ROUTING__CHAT_MODEL=
FINAGENT_LLM__ROUTING__ANALYSIS_MODEL=
FINAGENT_LLM__ROUTING__TAGGING_MODEL=
FINAGENT_LLM__ROUTING__EMBED_MODEL=
FINAGENT_LLM__ROUTING__SUMMARIZE_MODEL=

# HTTP server
FINAGENT_API__LISTEN=:8082

# Logging  (text for dev, json for prod)
FINAGENT_LOG__LEVEL=info
FINAGENT_LOG__FORMAT=text

# Agent behaviour
FINAGENT_AGENT__MAX_TOOL_ROUNDS=10
FINAGENT_AGENT__HISTORY_MESSAGES=20

# CLI default user (used when running without --user flag)
FINAGENT_CHANNEL__CLI__DEFAULT_USER=

# Per-user API keys  (add one entry per user defined in config.yaml users[])
# FINAGENT_API_KEYS__ALICE=<plaintext-key>
# FINAGENT_API_KEYS__BOB=<plaintext-key>
